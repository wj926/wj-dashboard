# wj-dashboard 환경변수 예시.
# 복사: cp .env.example .env  (또는 systemd EnvironmentFile=)

# 모드 (필수): prod | demo | dev
#   prod  — 본인 데이터로 운영 (인증 + 모든 경로 명시 필수)
#   demo  — 동봉된 페르소나 데모 데이터 (인증 없이 공개 가능)
#   dev   — 로컬 개발 (demo 와 동일하나 enable_chat 기본 ON)
WJ_MODE=demo

# 데이터 경로 (prod 면 필수, demo 면 examples/ 자동)
# WJ_DATA_PATH=/path/to/dashboard.yaml
# WJ_THINKING_ROOT=/path/to/thinking
# WJ_UPLOADS_DIR=/path/to/thinking/uploads
# WJ_TERM_LABEL_FILE=/path/to/term-labels.json

# Claude CLI (chat / 자연어 task 등록 / 터미널에서 호출)
# WJ_CLAUDE_BIN=/path/to/claude

# 기능 토글
WJ_ENABLE_TERMINAL=false   # WebSocket PTY (claude CLI 띄움). OSS 기본 OFF 권장.
WJ_ENABLE_CHAT=true        # 자연어 task 입력 / thinking 대화

# 인증 (prod 모드에서만 강제, demo 는 공개)
# WJ_PASSWORD=change-me

# 호스트/포트
WJ_HOST=127.0.0.1
WJ_PORT=3004
